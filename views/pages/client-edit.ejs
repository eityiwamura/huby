<% pageTitle = 'Editar Cliente'; activePage = 'clients'; %>

<div class="topbar">
  <a href="/clients/<%= client.id %>" style="color:var(--text-muted);text-decoration:none;font-size:13px;">← <%= client.name %></a>
  <div class="topbar-title" style="margin-left:12px;">Editar Cliente</div>
</div>

<div class="page-content">
  <div class="card" style="max-width:680px;">
    <div class="card-header"><div class="card-title">Dados do cliente</div></div>
    <div class="card-body">
      <% if (typeof error !== 'undefined' && error) { %>
        <div style="background:var(--red-dim);border:1px solid var(--red);color:var(--red);padding:10px 12px;border-radius:var(--radius-sm);margin-bottom:16px;font-size:13px;"><%= error %></div>
      <% } %>

      <form method="POST" action="/clients/<%= client.id %>/edit">
        <div class="grid-2">
          <div class="form-group">
            <label class="form-label">Nome *</label>
            <input type="text" name="name" class="form-input" value="<%= client.name %>" required>
          </div>
          <div class="form-group">
            <label class="form-label">Setor *</label>
            <select name="sector" class="form-select" required onchange="togglePolitical(this.value)">
              <option value="clinica" <%= client.sector==='clinica'?'selected':'' %>>Clínica</option>
              <option value="odontologia" <%= client.sector==='odontologia'?'selected':'' %>>Odontologia</option>
              <option value="ecommerce" <%= client.sector==='ecommerce'?'selected':'' %>>E-commerce</option>
              <option value="infoproduto" <%= client.sector==='infoproduto'?'selected':'' %>>Infoproduto</option>
              <option value="varejo_local" <%= client.sector==='varejo_local'?'selected':'' %>>Varejo Local</option>
              <option value="advocacia" <%= client.sector==='advocacia'?'selected':'' %>>Advocacia</option>
              <option value="imobiliaria" <%= client.sector==='imobiliaria'?'selected':'' %>>Imobiliária</option>
              <option value="educacao" <%= client.sector==='educacao'?'selected':'' %>>Educação</option>
              <option value="alimentacao" <%= client.sector==='alimentacao'?'selected':'' %>>Alimentação</option>
              <option value="beleza" <%= client.sector==='beleza'?'selected':'' %>>Beleza</option>
              <option value="politico" <%= client.sector==='politico'?'selected':'' %>>Político</option>
              <option value="outro" <%= client.sector==='outro'?'selected':'' %>>Outro</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Tipo de negócio</label>
          <input type="text" name="business_type" class="form-input" value="<%= client.business_type || '' %>">
        </div>

        <div class="form-group">
          <label class="form-label">Site (para análise PageSpeed)</label>
          <input type="text" name="website_url" class="form-input" value="<%= client.website_url || '' %>" placeholder="https://seusite.com.br">
        </div>

        <div class="grid-2">
          <div class="form-group">
            <label class="form-label">Cidade</label>
            <input type="text" name="city" class="form-input" value="<%= client.city || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Estado</label>
            <input type="text" name="state" class="form-input" value="<%= client.state || '' %>" maxlength="2">
          </div>
        </div>

        <div class="grid-2">
          <div class="form-group">
            <label class="form-label">WhatsApp (alertas)</label>
            <input type="text" name="phone" class="form-input" value="<%= client.phone || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Ticket médio (R$)</label>
            <input type="number" name="avg_ticket" class="form-input" value="<%= client.avg_ticket || '' %>">
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Projeto no Reportei (ID)</label>
          <input type="number" name="reportei_project_id" class="form-input" value="<%= client.reportei_project_id || '' %>">
        </div>

        <div id="political-fields" style="display:<%= client.sector==='politico'?'block':'none' %>;border-top:1px solid var(--border);margin-top:8px;padding-top:16px;">
          <div class="form-group">
            <label class="form-label" style="color:var(--purple);">⚖️ Dados políticos</label>
          </div>
          <div class="grid-2">
            <div class="form-group">
              <label class="form-label">Mandato</label>
              <select name="political_mandate" class="form-select">
                <option value="vereador" <%= client.political_mandate==='vereador'?'selected':'' %>>Vereador(a)</option>
                <option value="deputado_estadual" <%= client.political_mandate==='deputado_estadual'?'selected':'' %>>Deputado(a) Estadual</option>
                <option value="deputado_federal" <%= client.political_mandate==='deputado_federal'?'selected':'' %>>Deputado(a) Federal</option>
                <option value="senador" <%= client.political_mandate==='senador'?'selected':'' %>>Senador(a)</option>
                <option value="prefeito" <%= client.political_mandate==='prefeito'?'selected':'' %>>Prefeito(a)</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Próxima eleição (ano)</label>
              <input type="number" name="political_next_election" class="form-input" value="<%= client.political_next_election || 2026 %>">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Partido</label>
            <input type="text" name="political_party" class="form-input" value="<%= client.political_party || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Principais bandeiras</label>
            <textarea name="political_causes" class="form-textarea" rows="2"><%= client.political_causes || '' %></textarea>
          </div>
          <div class="form-group">
            <label class="form-label">Base eleitoral</label>
            <textarea name="political_base_description" class="form-textarea" rows="2"><%= client.political_base_description || '' %></textarea>
          </div>
        </div>

        <div class="flex gap-8" style="margin-top:8px;">
          <button type="submit" class="btn btn-primary">Salvar alterações</button>
          <a href="/clients/<%= client.id %>" class="btn btn-secondary">Cancelar</a>
          <button type="button" class="btn btn-danger" style="margin-left:auto;" onclick="confirmDelete()">🗑 Excluir cliente</button>
        </div>
      </form>

      <form id="form-delete" method="POST" action="/clients/<%= client.id %>/delete" style="display:none;"></form>
    </div>
  </div>
</div>

<script>
function togglePolitical(val) {
  document.getElementById('political-fields').style.display = val === 'politico' ? 'block' : 'none';
}
function confirmDelete() {
  if (confirm('Tem certeza que deseja excluir este cliente? Todos os dados serão perdidos.')) {
    document.getElementById('form-delete').submit();
  }
}
</script>
