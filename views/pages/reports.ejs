<% pageTitle = 'Relatórios'; activePage = 'reports'; %>

<div class="topbar">
  <div class="topbar-title">Relatórios</div>
  <div class="topbar-actions">
    <select class="form-select" style="width:200px;" id="report-client" onchange="loadReport()">
      <option value="">Selecione o cliente...</option>
      <% clients.forEach(function(c) { %>
        <option value="<%= c.id %>"><%= c.name %></option>
      <% }) %>
    </select>
    <select class="form-select" style="width:140px;" id="report-period" onchange="loadReport()">
      <option value="30">Últimos 30 dias</option>
      <option value="7">Últimos 7 dias</option>
      <option value="60">Últimos 60 dias</option>
      <option value="90">Últimos 90 dias</option>
    </select>
    <button class="btn btn-secondary btn-sm" onclick="exportPDF()">📄 PDF</button>
    <button class="btn btn-secondary btn-sm" onclick="shareReport()">🔗 Compartilhar</button>
  </div>
</div>

<div class="page-content">
  <div id="report-empty" class="empty-state">
    <div class="empty-icon">📊</div>
    <div class="empty-title">Selecione um cliente</div>
  </div>

  <div id="report-loading" style="display:none;" class="loading-overlay"><div class="spinner"></div> Coletando dados...</div>

  <div id="report-content" style="display:none;">

    <!-- Header -->
    <div class="card mb-16">
      <div class="card-body">
        <div class="flex-center gap-16" style="justify-content:space-between;flex-wrap:wrap;">
          <div>
            <div style="font-size:18px;font-weight:700;" id="rpt-name">—</div>
            <div style="font-size:13px;color:var(--text-muted);" id="rpt-period">—</div>
          </div>
          <div id="rpt-overall-scores" class="flex gap-8 flex-wrap"></div>
        </div>
      </div>
    </div>

    <!-- KPIs -->
    <div id="report-kpis" class="stats-grid mb-16"></div>

    <!-- Gráficos de evolução temporal -->
    <div class="card mb-16">
      <div class="card-header">
        <div class="card-title">📈 Evolução ao longo do tempo</div>
        <div class="flex gap-8">
          <button class="btn btn-secondary btn-sm active-metric" id="btn-metric-followers" onclick="switchMetric('followers', this)">Seguidores</button>
          <button class="btn btn-secondary btn-sm" id="btn-metric-reach" onclick="switchMetric('reach', this)">Alcance</button>
          <button class="btn btn-secondary btn-sm" id="btn-metric-spend" onclick="switchMetric('spend', this)">Investimento</button>
          <button class="btn btn-secondary btn-sm" id="btn-metric-clicks" onclick="switchMetric('clicks', this)">Cliques</button>
        </div>
      </div>
      <div class="card-body">
        <canvas id="chart-evolution" height="120"></canvas>
      </div>
    </div>

    <!-- Gráficos secundários -->
    <div class="grid-2 gap-16 mb-16">
      <div class="card">
        <div class="card-header"><div class="card-title">💰 Budget por plataforma</div></div>
        <div class="card-body"><canvas id="chart-budget-split" height="200"></canvas></div>
      </div>
      <div class="card">
        <div class="card-header"><div class="card-title">📊 Engajamento por rede</div></div>
        <div class="card-body"><canvas id="chart-engagement" height="200"></canvas></div>
      </div>
    </div>

    <!-- Comparativo de períodos -->
    <div class="card mb-16">
      <div class="card-header"><div class="card-title">🔄 Comparativo vs período anterior</div></div>
      <div class="card-body" id="report-comparison"></div>
    </div>

    <!-- Análise IA -->
    <div class="card mb-16">
      <div class="card-header">
        <div class="card-title">🤖 Insights IA</div>
        <button class="btn btn-primary btn-sm" onclick="generateInsights()" id="btn-insights">Gerar insights</button>
      </div>
      <div id="report-insights" class="card-body">
        <div style="color:var(--text-muted);font-size:13px;">Clique em "Gerar insights" para análise completa.</div>
      </div>
    </div>

    <!-- Relatórios salvos -->
    <div class="card">
      <div class="card-header"><div class="card-title">📋 Relatórios salvos</div></div>
      <div id="saved-reports-list" class="card-body"></div>
    </div>

  </div>
</div>

<!-- Modal compartilhar -->
<div id="modal-share" style="display:none;" class="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">🔗 Link público</div>
      <button class="modal-close" onclick="this.closest('.modal-overlay').style.display='none'">×</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Compartilhe com o cliente:</label>
        <input type="text" class="form-input" id="share-link" readonly onclick="this.select()">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-primary" onclick="copyLink()">📋 Copiar</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
var currentClientId = null;
var currentData = null;
var evolutionChart = null;
var budgetChart = null;
var engagementChart = null;
var allMetrics = {};
var currentMetric = 'followers';

function loadReport() {
  var clientId = document.getElementById('report-client').value;
  if (!clientId) return;
  var days = parseInt(document.getElementById('report-period').value);
  currentClientId = clientId;

  var end = new Date().toISOString().split('T')[0];
  var start = new Date(Date.now() - days * 86400000).toISOString().split('T')[0];

  document.getElementById('report-empty').style.display = 'none';
  document.getElementById('report-content').style.display = 'none';
  document.getElementById('report-loading').style.display = 'flex';

  fetch('/api/reports/data?clientId=' + clientId + '&start=' + start + '&end=' + end + '&history=true')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      currentData = data;
      renderReport(data, start, end);
      loadSavedReports(clientId);
    })
    .catch(function(err) { alert('Erro: ' + err.message); })
    .finally(function() { document.getElementById('report-loading').style.display = 'none'; });
}

function renderReport(data, start, end) {
  document.getElementById('rpt-name').textContent = data.client_name || '—';
  document.getElementById('rpt-period').textContent = new Date(start).toLocaleDateString('pt-BR') + ' a ' + new Date(end).toLocaleDateString('pt-BR');

  // KPIs
  var kpiHtml = '';
  (data.kpis || []).forEach(function(k) {
    var trendHtml = k.trend > 0 ? '<div style="color:var(--green);font-size:11px;margin-top:2px;">▲ ' + k.trend + '%</div>' : k.trend < 0 ? '<div style="color:var(--red);font-size:11px;margin-top:2px;">▼ ' + Math.abs(k.trend) + '%</div>' : '';
    kpiHtml += '<div class="stat-card"><div class="stat-label">' + k.label + '</div><div class="stat-value accent" style="font-size:20px;">' + k.value + '</div>' + trendHtml + '</div>';
  });
  document.getElementById('report-kpis').innerHTML = kpiHtml;

  // Guardar dados de métricas para o gráfico de evolução
  allMetrics = data.metrics_history || {};
  renderEvolutionChart(currentMetric);

  // Gráfico de budget por plataforma
  if (budgetChart) budgetChart.destroy();
  var bdData = data.budget_by_platform || {};
  var ctx2 = document.getElementById('chart-budget-split').getContext('2d');
  budgetChart = new Chart(ctx2, {
    type: 'doughnut',
    data: {
      labels: Object.keys(bdData),
      datasets: [{ data: Object.values(bdData), backgroundColor: ['rgba(91,110,245,0.8)','rgba(34,197,94,0.8)','rgba(245,158,11,0.8)','rgba(239,68,68,0.8)'] }]
    },
    options: { responsive: true, plugins: { legend: { labels: { color: '#e8eaf0', font: { size: 11 } } } } }
  });

  // Gráfico de engajamento por rede
  if (engagementChart) engagementChart.destroy();
  var enData = data.engagement_by_platform || {};
  var ctx3 = document.getElementById('chart-engagement').getContext('2d');
  engagementChart = new Chart(ctx3, {
    type: 'bar',
    data: {
      labels: Object.keys(enData),
      datasets: [{ label: 'Engajamento (%)', data: Object.values(enData), backgroundColor: 'rgba(91,110,245,0.8)' }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: '#6b7394' }, grid: { color: '#1f2433' } },
        y: { ticks: { color: '#6b7394' }, grid: { color: '#1f2433' } }
      }
    }
  });

  // Comparativo
  var compHtml = '<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;">';
  compHtml += '<tr style="font-size:11px;color:var(--text-muted);text-transform:uppercase;"><th style="text-align:left;padding:8px;border-bottom:1px solid var(--border);">Métrica</th><th style="text-align:right;padding:8px;border-bottom:1px solid var(--border);">Período atual</th><th style="text-align:right;padding:8px;border-bottom:1px solid var(--border);">Período anterior</th><th style="text-align:right;padding:8px;border-bottom:1px solid var(--border);">Variação</th></tr>';
  (data.comparison || []).forEach(function(c) {
    var varColor = c.variation > 0 ? 'var(--green)' : c.variation < 0 ? 'var(--red)' : 'var(--text-muted)';
    var varIcon = c.variation > 0 ? '▲' : c.variation < 0 ? '▼' : '—';
    compHtml += '<tr style="border-bottom:1px solid var(--border);"><td style="padding:10px 8px;font-size:13px;">' + c.metric + '</td><td style="padding:10px 8px;text-align:right;font-size:13px;font-weight:600;">' + c.current + '</td><td style="padding:10px 8px;text-align:right;font-size:13px;color:var(--text-muted);">' + c.previous + '</td><td style="padding:10px 8px;text-align:right;font-size:13px;font-weight:600;color:' + varColor + ';">' + varIcon + ' ' + Math.abs(c.variation) + '%</td></tr>';
  });
  compHtml += '</table></div>';
  document.getElementById('report-comparison').innerHTML = compHtml;

  document.getElementById('report-content').style.display = 'block';
}

function renderEvolutionChart(metricKey) {
  if (evolutionChart) evolutionChart.destroy();
  var metricData = allMetrics[metricKey] || { labels: [], data: [] };
  var ctx = document.getElementById('chart-evolution').getContext('2d');

  var metricColors = {
    followers: '#5b6ef5', reach: '#22c55e', spend: '#ef4444', clicks: '#f59e0b'
  };
  var color = metricColors[metricKey] || '#5b6ef5';

  evolutionChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: metricData.labels || [],
      datasets: [{
        label: metricKey,
        data: metricData.data || [],
        borderColor: color,
        backgroundColor: color.replace(')', ',0.1)').replace('rgb', 'rgba'),
        tension: 0.4, fill: true, pointRadius: 3
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: '#6b7394', maxTicksLimit: 12 }, grid: { color: '#1f2433' } },
        y: { ticks: { color: '#6b7394' }, grid: { color: '#1f2433' } }
      }
    }
  });
}

function switchMetric(metric, btn) {
  currentMetric = metric;
  document.querySelectorAll('.active-metric').forEach(function(b) { b.classList.remove('active-metric'); b.style.color = ''; });
  btn.classList.add('active-metric');
  renderEvolutionChart(metric);
}

function generateInsights() {
  var days = parseInt(document.getElementById('report-period').value);
  var end = new Date().toISOString().split('T')[0];
  var start = new Date(Date.now() - days * 86400000).toISOString().split('T')[0];
  var el = document.getElementById('report-insights');
  el.innerHTML = '<div class="loading-overlay"><div class="spinner"></div> Gerando com IA...</div>';
  document.getElementById('btn-insights').disabled = true;

  fetch('/api/clients/' + currentClientId + '/analyze', {
    credentials: 'same-origin', method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ analysisType: 'full', periodStart: start, periodEnd: end })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.error) throw new Error(data.error);
    var p = data.parsed;
    var html = '';
    if (p.diagnosis) html += '<div class="analysis-section"><h3>Diagnóstico</h3><div class="diagnosis-text">' + p.diagnosis.replace(/\n/g,'<br>') + '</div></div>';
    var ap = p.action_plan || [];
    if (ap.length) {
      html += '<div class="analysis-section"><h3>🎯 Top ações recomendadas</h3>';
      ap.slice(0,4).forEach(function(a) {
        html += '<div class="action-item"><div class="action-priority">' + a.priority + '</div><div style="flex:1;"><div class="action-title">' + a.action + '</div><div class="action-reason">' + a.reason + '</div>' + (a.expected_impact ? '<div class="action-impact">📈 ' + a.expected_impact + '</div>' : '') + '</div></div>';
      });
      html += '</div>';
    }
    if (p.projection) html += '<div class="analysis-section"><h3>📈 Projeção</h3><div class="diagnosis-text">' + p.projection.replace(/\n/g,'<br>') + '</div></div>';
    el.innerHTML = html;
  }).catch(function(err) { el.innerHTML = '<div style="color:var(--red);padding:16px;">Erro: ' + err.message + '</div>'; })
  .finally(function() { document.getElementById('btn-insights').disabled = false; });
}

function loadSavedReports(clientId) {
  fetch('/api/reports/saved?clientId=' + clientId).then(function(r) { return r.json(); }).then(function(data) {
    var reports = data.reports || [];
    var html = '';
    if (!reports.length) {
      html = '<div style="color:var(--text-muted);font-size:13px;padding:16px;">Nenhum relatório salvo ainda</div>';
    } else {
      reports.forEach(function(r) {
        html += '<div class="alert-item"><div style="font-size:20px;">📊</div><div class="alert-content"><div class="alert-title">' + r.title + '</div><div class="alert-client">' + new Date(r.period_start).toLocaleDateString('pt-BR') + ' — ' + new Date(r.period_end).toLocaleDateString('pt-BR') + '</div></div><div class="flex gap-8"><a href="/reports/pdf/' + r.uuid + '" target="_blank" class="btn btn-secondary btn-sm">📄 PDF</a><button class="btn btn-secondary btn-sm" onclick="copyShareLink(\'' + r.uuid + '\')">🔗</button><button class="btn btn-danger btn-sm" onclick="deleteReport(\'' + r.uuid + '\',this)">🗑</button></div></div>';
      });
    }
    document.getElementById('saved-reports-list').innerHTML = html;
  });
}

function exportPDF() {
  if (!currentClientId) { alert('Selecione um cliente'); return; }
  var days = parseInt(document.getElementById('report-period').value);
  var end = new Date().toISOString().split('T')[0];
  var start = new Date(Date.now() - days * 86400000).toISOString().split('T')[0];
  fetch('/api/reports/save', { credentials: 'same-origin', method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ clientId: currentClientId, start: start, end: end, data: currentData }) })
    .then(function(r) { return r.json(); }).then(function(data) {
      window.open('/reports/pdf/' + data.uuid, '_blank');
      loadSavedReports(currentClientId);
    });
}

function shareReport() {
  if (!currentClientId) { alert('Selecione um cliente'); return; }
  var days = parseInt(document.getElementById('report-period').value);
  var end = new Date().toISOString().split('T')[0];
  var start = new Date(Date.now() - days * 86400000).toISOString().split('T')[0];
  fetch('/api/reports/save', { credentials: 'same-origin', method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ clientId: currentClientId, start: start, end: end, data: currentData }) })
    .then(function(r) { return r.json(); }).then(function(data) {
      document.getElementById('share-link').value = window.location.origin + '/reports/public/' + data.token;
      document.getElementById('modal-share').style.display = 'flex';
      loadSavedReports(currentClientId);
    });
}

function copyShareLink(uuid) {
  fetch('/api/reports/' + uuid + '/token').then(function(r) { return r.json(); }).then(function(data) {
    navigator.clipboard.writeText(window.location.origin + '/reports/public/' + data.token).then(function() { alert('Link copiado!'); });
  });
}

function copyLink() { document.getElementById('share-link').select(); document.execCommand('copy'); alert('Copiado!'); }

function deleteReport(uuid, btn) {
  if (!confirm('Deletar este relatório?')) return;
  btn.disabled = true;
  fetch('/api/reports/' + uuid, { credentials: 'same-origin', method: 'DELETE' }).then(function() { loadSavedReports(currentClientId); });
}
</script>
